                (fpadstack
                  (pt 32500 -161300)
                  (angle 0)
                  (padstackGroup default (padstack r60_40))
                )
              )
            )
          )
          (pin 4
            (pt 97500 -161300)
            (layout
              (layer (FPADSTACK)
                (fpadstack
                  (pt 97500 -161300)
                  (angle 0)
                  (padstackGroup default (padstack r60_40))
                )
              )
            )
          )
          (pin 5
            (pt 97500 161300)
            (layout
              (layer (FPADSTACK)
                (fpadstack
                  (pt 97500 161300)
                  (angle 0)
                  (padstackGroup default (padstack r55_40))
                )
              )
            )
