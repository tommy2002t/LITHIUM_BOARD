(ftf
  (header
    (version 2.0)
    (unit DBUNIT)
  )
  (TechnologyContainer
    (technology SamacSys_Footprint
      (footprintLayer
        (layer Top (type Conductive))
        (layer Inner (type Conductive))
        (layer Bottom (type Conductive))
        (layer Silk-Top (type Symbolmark))
        (layer Silk-Bottom (type Symbolmark))
        (layer Resist-Top (type Solderresist))
        (layer Resist-Bottom (type Solderresist))
        (layer MetalMask-Top (type Metalmask))
        (layer MetalMask-Bottom (type Metalmask))
        (layer CompArea-Top (type Comparea))
        (layer CompArea-Bottom (type Comparea))
        (layer Assembly-Top (type Undefined))
        (layer Assembly-Bottom (type Undefined))
        (layer Hole (type Hole))
      )
    )
  )
  (footprintContainer
    (commonParameters
      (dimensionParameters
        (arrowLength 100000)
        (arrowAngle 15.000000)
        (dotDiameter 100000)
        (textFrameOffset 100000)
        (arrowOffset 100000)
        (dimAssistOffset 100000)
        (dimLineWidth 10000)
        (drawTextFrame NO)
        (textFrameRange ALL)
        (textClip NO)
        (standard JIS)
      )
    )
    (padstackGroups
      (padstackGroup default)
    )
    (pads
      (pad r60_40
        (photo FLASH)
        (panelUse NO)
        (geometry
          (rectangle
            (pt 0 0)
            (width 40000)
            (height 60000)
            (rAngle 0.000000)
            (outlineWidth 0)
            (fillWidth 0)
            (fillAngle 0.000000)
          )
        )
      )
      (pad r55_40
        (photo FLASH)
        (panelUse NO)
        (geometry
          (rectangle
            (pt 0 0)
            (width 40000)
            (height 55000)
            (rAngle 0.000000)
            (outlineWidth 0)
            (fillWidth 0)
            (fillAngle 0.000000)
          )
        )
      )
      (pad r265_203
        (photo FLASH)
        (panelUse NO)
        (geometry
          (rectangle
            (pt 0 0)
            (width 203000)
            (height 265000)
            (rAngle 0.000000)
            (outlineWidth 0)
            (fillWidth 0)
            (fillAngle 0.000000)
          )
        )
      )
    ); End of pads
    (padstacks
      (padstack r60_40
        (type NONPLATED)
        (throughMode NONTHROUGH)
        (panelUse NO)
        (padSet (footLayer Top)
          (connect (pad r60_40))
          (noconnect (pad r60_40))
        )
        (padSet (footLayer Resist-Top)
          (connect (pad r60_40))
          (noconnect (pad r60_40))
        )
        (padSet (footLayer MetalMask-Top)
          (connect (pad r60_40))
          (noconnect (pad r60_40))
        )
      )
      (padstack r55_40
        (type NONPLATED)
        (throughMode NONTHROUGH)
        (panelUse NO)
        (padSet (footLayer Top)
          (connect (pad r55_40))
          (noconnect (pad r55_40))
        )
        (padSet (footLayer Resist-Top)
          (connect (pad r55_40))
          (noconnect (pad r55_40))
        )
        (padSet (footLayer MetalMask-Top)
          (connect (pad r55_40))
          (noconnect (pad r55_40))
        )
      )
      (padstack r55_40
        (type NONPLATED)
        (throughMode NONTHROUGH)
        (panelUse NO)
        (padSet (footLayer Top)
          (connect (pad r55_40))
          (noconnect (pad r55_40))
        )
        (padSet (footLayer Resist-Top)
          (connect (pad r55_40))
          (noconnect (pad r55_40))
        )
        (padSet (footLayer MetalMask-Top)
          (connect (pad r55_40))
          (noconnect (pad r55_40))
        )
      )
      (padstack r55_40
        (type NONPLATED)
        (throughMode NONTHROUGH)
        (panelUse NO)
        (padSet (footLayer Top)
          (connect (pad r55_40))
          (noconnect (pad r55_40))
        )
        (padSet (footLayer Resist-Top)
          (connect (pad r55_40))
          (noconnect (pad r55_40))
        )
        (padSet (footLayer MetalMask-Top)
          (connect (pad r55_40))
          (noconnect (pad r55_40))
        )
      )
      (padstack r55_40
        (type NONPLATED)
        (throughMode NONTHROUGH)
        (panelUse NO)
        (padSet (footLayer Top)
          (connect (pad r55_40))
          (noconnect (pad r55_40))
        )
        (padSet (footLayer Resist-Top)
          (connect (pad r55_40))
          (noconnect (pad r55_40))
        )
        (padSet (footLayer MetalMask-Top)
          (connect (pad r55_40))
          (noconnect (pad r55_40))
        )
      )
      (padstack r265_203
        (type NONPLATED)
        (throughMode NONTHROUGH)
        (panelUse NO)
        (padSet (footLayer Top)
          (connect (pad r265_203))
          (noconnect (pad r265_203))
        )
        (padSet (footLayer Resist-Top)
          (connect (pad r265_203))
          (noconnect (pad r265_203))
        )
        (padSet (footLayer MetalMask-Top)
          (connect (pad r265_203))
          (noconnect (pad r265_203))
        )
      )
    ); End of padstacks
    (footprints
      (footprint "PXN8R330QLJ"
        (polarity YES)
        (panelUse NO)
        (heelprint
          (layout
            (layer (footLayer Assembly-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (pt -157500 -151200
                        (width 10000)
                      )
                      (pt 157500 -151200
                        (width 10000)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Assembly-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (pt 157500 -151200
                        (width 10000)
                      )
                      (pt 157500 148800
                        (width 10000)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Assembly-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (pt 157500 148800
                        (width 10000)
                      )
                      (pt -157500 148800
                        (width 10000)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Assembly-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (pt -157500 148800
                        (width 10000)
                      )
                      (pt -157500 -151200
                        (width 10000)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer CompArea-Top)
              (area
                (geometry
                  (surface
                    (outlineWidth 0)
                    (fillWidth 0)
                    (fillAngle 0.000000)
                    (vertex
                    (pt 257500 288800)
                    (pt 257500 -291300)
                    (pt -257500 -291300)
                    (pt -257500 288800)
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (pt -157500 -151200
                        (width 20000)
                      )
                      (pt -157500 -151200
                        (width 20000)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (pt -157500 -151200
                        (width 20000)
                      )
                      (pt -157500 -91200
                        (width 20000)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (pt 157500 -151200
                        (width 20000)
                      )
                      (pt 157500 -151200
                        (width 20000)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (pt 157500 -151200
                        (width 20000)
                      )
                      (pt 157500 -91200
                        (width 20000)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (pt -100000 -240000
                        (width 10000)
                      )
                      (pt -100000 -240000
                        (width 10000)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (arc CCW
                        (r 5000)
                        (begin
                          (pt -100000 -240000
                            (width 10000)
                          )
                        )
                        (center 1073741824 0)
                        (end
                          (pt -90000 -240000
                            (width 10000)
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (arc CCW
                        (r 5000)
                        (begin
                          (pt -90000 -240000
                            (width 10000)
                          )
                        )
                        (center -1073741824 0)
                        (end
                          (pt -100000 -240000
                            (width 10000)
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
           ); End of layout
         ); End of heelprint
         (toeprint
          (pin 1
            (pt -97500 -161300)
            (layout
              (layer (FPADSTACK)
                (fpadstack
                  (pt -97500 -161300)
                  (angle 0)
                  (padstackGroup default (padstack r60_40))
                )
              )
            )
          )
          (pin 2
            (pt -32500 -161300)
            (layout
              (layer (FPADSTACK)
                (fpadstack
                  (pt -32500 -161300)
                  (angle 0)
                  (padstackGroup default (padstack r60_40))
                )
              )
            )
          )
          (pin 3
            (pt 32500 -161300)
            (layout
