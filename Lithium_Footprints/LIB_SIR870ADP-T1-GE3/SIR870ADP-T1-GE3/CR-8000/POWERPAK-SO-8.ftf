                  (line
                    (vertex
                      (pt 0 -235000
                        (width 25400)
                      )
                      (pt 0 -255000
                        (width 25400)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (pt 0 -362000
                        (width 25400)
                      )
                      (pt 0 -382000
                        (width 25400)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (pt 589000 -235000
                        (width 25400)
                      )
                      (pt 589000 -255000
                        (width 25400)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (pt 589000 -362000
                        (width 25400)
                      )
                      (pt 589000 -382000
                        (width 25400)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (arc CW
                        (r 4589)
                        (begin
                          (pt -86700 8689
                            (width 25400)
                          )
                        )
                        (center 0 0)
                        (end
                          (pt -86700 8689
                            (width 25400)
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
           ); End of layout
         ); End of heelprint
         (toeprint
          (pin 1
            (pt 21250 -54500)
            (layout
              (layer (FPADSTACK)
                (fpadstack
                  (pt 21250 -54500)
                  (angle 90)
                  (padstackGroup default (padstack r127_61))
                )
              )
            )
          )
          (pin 2
            (pt 21250 -181500)
            (layout
              (layer (FPADSTACK)
                (fpadstack
                  (pt 21250 -181500)
                  (angle 90)
                  (padstackGroup default (padstack r127_61))
                )
              )
            )
          )
          (pin 3
            (pt 21250 -308500)
