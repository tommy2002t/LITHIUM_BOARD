                    (vertex
                      (pt 0 0
                        (width 25400)
                      )
                      (pt 589000 0
                        (width 25400)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (pt 0 -108000
                        (width 25400)
                      )
                      (pt 0 -128000
                        (width 25400)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (pt 589000 -108000
                        (width 25400)
                      )
                      (pt 589000 -128000
                        (width 25400)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
