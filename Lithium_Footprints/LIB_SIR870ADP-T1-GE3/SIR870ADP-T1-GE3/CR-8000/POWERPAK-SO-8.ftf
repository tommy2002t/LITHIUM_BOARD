                  (pt 21250 -435500)
                  (angle 90)
                  (padstackGroup default (padstack r127_61))
                )
              )
            )
          )
          (pin 5
            (pt 567750 -435500)
            (layout
              (layer (FPADSTACK)
                (fpadstack
                  (pt 567750 -435500)
                  (angle 90)
                  (padstackGroup default (padstack r102_61))
                )
              )
            )
          )
          (pin 6
            (pt 567750 -308500)
            (layout
              (layer (FPADSTACK)
                (fpadstack
                  (pt 567750 -308500)
                  (angle 90)
                  (padstackGroup default (padstack r102_61))
                )
