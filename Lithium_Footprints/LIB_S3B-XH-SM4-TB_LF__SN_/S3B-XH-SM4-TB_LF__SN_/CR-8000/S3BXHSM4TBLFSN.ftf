                (fpadstack
                  (pt -250000 -427500)
                  (angle 0)
                  (padstackGroup default (padstack r450_130))
                )
              )
            )
          )
          (pin MP1
            (pt 570000 252500)
            (layout
              (layer (FPADSTACK)
                (fpadstack
                  (pt 570000 252500)
                  (angle 0)
                  (padstackGroup default (padstack r390_180))
                )
              )
            )
          )
          (pin MP2
            (pt -570000 252500)
            (layout
              (layer (FPADSTACK)
                (fpadstack
                  (pt -570000 252500)
                  (angle 0)
                  (padstackGroup default (padstack r390_180))
                )
              )
            )
          )
        ); End of toeprint
        (propertyS accurateShape S3B-XH-SM4-TB_LF__SN_.stp)
      ); End of footprint
    ); End of footprints
  );  End of footprintContainer
); End of ftf

